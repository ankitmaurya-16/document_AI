# Copy to .env and fill in real values. NEVER commit .env.
# In production, inject these via your secrets manager (AWS SM / Vault / K8s Secret).

# --- Core ---
APP_ENV=development                   # development | production | test
FLASK_DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false                        # true in prod (JSON lines for aggregation)
PORT=5001

# --- Security ---
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# --- HTTP ---
# Explicit comma-separated allow-list. '*' is rejected in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Per-file limit (MB) and per-user cumulative quota.
MAX_UPLOAD_MB=16
MAX_FILES_PER_REQUEST=10
PER_USER_STORAGE_MB=200

# --- Rate limits (flask-limiter syntax) ---
RATE_LIMIT_DEFAULT=200/hour
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_UPLOAD=10/minute

# --- Cache / queue (Phase 2) ---
# REDIS_URL enables Redis for (a) response cache, (b) semantic cache, (c) job state.
# Leave empty to use in-memory fallback (single-process dev only).
REDIS_URL=
# ASYNC_MODE=celery runs ingestion on a Celery worker. ASYNC_MODE=sync (default) runs inline.
# Worker: celery -A tasks.celery_app worker --loglevel=info --concurrency=2
ASYNC_MODE=sync
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Rate-limiter Redis backend (optional; improves accuracy across multiple gunicorn workers).
RATELIMIT_STORAGE_URI=

# --- MongoDB pool ---
MONGO_MAX_POOL=50
MONGO_MIN_POOL=5
MONGO_SERVER_TIMEOUT_MS=5000

# --- Retrieval tuning ---
# Set RERANK_DISABLE=1 to skip the cross-encoder (useful when offline).
RERANK_DISABLE=
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Datastore (REQUIRED in production) ---
MONGODB_URI=mongodb://localhost:27017
DB_NAME=rag_chat_app

# --- LLM (OpenAI-compatible; REQUIRED in production) ---
OPENAI_API_KEY=
# Point at any OpenAI-compatible endpoint to swap providers. Leave empty for OpenAI.
#   Groq:   https://api.groq.com/openai/v1        (LLM_MODEL=llama-3.3-70b-versatile)
#   Gemini: https://generativelanguage.googleapis.com/v1beta/openai/  (LLM_MODEL=gemini-2.0-flash)
#   Ollama: http://localhost:11434/v1             (LLM_MODEL=llama3.2)
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# --- Google OAuth (optional) ---
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

TOKENIZERS_PARALLELISM=false
