# Copy to .env.docker and fill in. Compose reads this automatically.
# NEVER commit .env.docker.

APP_ENV=development
ASYNC_MODE=sync

# Required
JWT_SECRET=replace-me-with-64-random-bytes
OPENAI_API_KEY=
# Optional: swap to any OpenAI-compatible provider (Groq / Gemini / Ollama).
# Leave OPENAI_BASE_URL empty for OpenAI. Examples in backend/.env.example.
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Optional
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SENTRY_DSN=

# Stripe (test mode) — Wave B
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
VITE_STRIPE_PUBLISHABLE_KEY=

# Qdrant (Wave C). Leave QDRANT_URL empty to keep the FAISS local-disk index.
# Enable with `docker compose --profile qdrant up` and set QDRANT_URL=http://qdrant:6333
QDRANT_URL=
VECTOR_BACKEND=

# MinIO / S3 (Wave C). Leave S3_BUCKET empty to keep raw uploads on local disk.
# Enable with `docker compose --profile minio up` and set:
#   S3_ENDPOINT=http://minio:9000
#   S3_BUCKET=docai
#   AWS_ACCESS_KEY_ID=minioadmin
#   AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Observability (Wave D). Empty = telemetry stays no-op. Enable with:
#   docker compose --profile observability up
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# Grafana login (anon viewer is on by default; admin for editing):
#   GRAFANA_ADMIN_USER=admin
#   GRAFANA_ADMIN_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
