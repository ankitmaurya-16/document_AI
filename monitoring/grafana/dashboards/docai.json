{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(flask_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Request rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(flask_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(flask_http_request_total[5m])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "title": "Error rate (5xx ratio)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(docai_ingestion_duration_seconds_bucket[15m])))",
          "legendFormat": "ingest p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(docai_ingestion_duration_seconds_bucket[15m])))",
          "legendFormat": "ingest p50",
          "refId": "B"
        }
      ],
      "title": "Ingestion duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "sum by (layer) (rate(docai_cache_hit_total[5m])) / clamp_min(sum by (layer) (rate(docai_cache_hit_total[5m]) + rate(docai_cache_miss_total[5m])), 1)",
          "legendFormat": "{{layer}} hit ratio",
          "refId": "A"
        }
      ],
      "title": "Cache hit ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 6,
      "targets": [
        {
          "expr": "sum by (route) (rate(docai_credit_burn_total[5m])) * 60",
          "legendFormat": "{{route}} credits/min",
          "refId": "A"
        }
      ],
      "title": "Credit burn rate (credits/min)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
